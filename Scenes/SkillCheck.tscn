[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/SkillCheck.gd" id="1_skill_check"]
[ext_resource type="Script" path="res://Scripts/SkillCheckCanvas.gd" id="2_canvas"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.1, 0.1, 0.15, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.3, 0.5, 0.8, 0.95)
corner_radius_top_left = 12
corner_radius_top_right = 12
corner_radius_bottom_right = 12
corner_radius_bottom_left = 12

[sub_resource type="Theme" id="Theme_skill_check"]
default_font_sizes/font_size = 24

[node name="SkillCheck" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
script = ExtResource("1_skill_check")

[node name="ColorRect" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)
mouse_filter = 1

[node name="PopupPanel" type="PanelContainer" parent="."]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 0.0
anchor_right = 0.5
anchor_bottom = 0.0
offset_left = -180.0
offset_top = 50.0
offset_right = 180.0
offset_bottom = 400.0
grow_horizontal = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="VBoxContainer" type="VBoxContainer" parent="PopupPanel"]
layout_mode = 2
theme = SubResource("Theme_skill_check")
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="PopupPanel/VBoxContainer"]
layout_mode = 2
text = "SKILL CHECK!"
horizontal_alignment = 1
vertical_alignment = 1
custom_minimum_size = Vector2(0, 40)

[node name="InstructionLabel" type="Label" parent="PopupPanel/VBoxContainer"]
layout_mode = 2
text = "Click at the right time"
horizontal_alignment = 1
custom_minimum_size = Vector2(0, 30)
theme_override_font_sizes/font_size = 14

[node name="SkillCheckCanvas" type="Control" parent="PopupPanel/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(280, 280)
size_flags_horizontal = 4
script = ExtResource("2_canvas")

[node name="TimerLabel" type="Label" parent="PopupPanel/VBoxContainer"]
layout_mode = 2
text = "5.0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18

[node name="SuccessSound" type="AudioStreamPlayer" parent="."]
bus = &"Master"

[node name="FailSound" type="AudioStreamPlayer" parent="."]
bus = &"Master"
